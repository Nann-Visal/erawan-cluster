{
  "info": {
    "_postman_id": "0f487bb5-3f07-49a9-9b29-e468f795d8d5",
    "name": "Erawan Cluster API (Go)",
    "description": "Postman collection for HAProxy and MySQL cluster endpoints",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "API_HOST", "value": "127.0.0.1" },
    { "key": "API_PORT", "value": "8080" },
    { "key": "API_KEY", "value": "" },
    { "key": "JOB_ID", "value": "" },
    { "key": "ROOT_PASSWORD", "value": "RootPass#2026" },
    { "key": "CLUSTER_ADMIN_USERNAME", "value": "clusteradmin" },
    { "key": "CLUSTER_ADMIN_PASSWORD", "value": "ClusterAdmin#2026" },
    { "key": "SSH_PASSWORD", "value": "password" },
    { "key": "PRIMARY_IP", "value": "192.168.122.154" },
    { "key": "SECONDARY_IP", "value": "192.168.122.111" },
    { "key": "CLUSTER_NAME", "value": "prodCluster" }
  ],
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "header": [
          { "key": "X-API-Key", "value": "{{API_KEY}}", "disabled": true }
        ],
        "url": {
          "raw": "http://{{API_HOST}}:{{API_PORT}}/health",
          "protocol": "http",
          "host": ["{{API_HOST}}"],
          "port": "{{API_PORT}}",
          "path": ["health"]
        }
      }
    },
    {
      "name": "Docs",
      "request": {
        "method": "GET",
        "header": [
          { "key": "X-API-Key", "value": "{{API_KEY}}", "disabled": true }
        ],
        "url": {
          "raw": "http://{{API_HOST}}:{{API_PORT}}/docs",
          "protocol": "http",
          "host": ["{{API_HOST}}"],
          "port": "{{API_PORT}}",
          "path": ["docs"]
        }
      }
    },
    {
      "name": "HAProxy Create Config",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "X-API-Key", "value": "{{API_KEY}}", "disabled": true }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"port\": 25010,\n  \"node_ips\": [\"10.10.107.182\", \"10.10.107.183\"],\n  \"db_port\": 6446\n}"
        },
        "url": {
          "raw": "http://{{API_HOST}}:{{API_PORT}}/haproxy/config",
          "protocol": "http",
          "host": ["{{API_HOST}}"],
          "port": "{{API_PORT}}",
          "path": ["haproxy", "config"]
        }
      }
    },
    {
      "name": "HAProxy Delete Config",
      "request": {
        "method": "DELETE",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "X-API-Key", "value": "{{API_KEY}}", "disabled": true }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"port\": 25010\n}"
        },
        "url": {
          "raw": "http://{{API_HOST}}:{{API_PORT}}/haproxy/config",
          "protocol": "http",
          "host": ["{{API_HOST}}"],
          "port": "{{API_PORT}}",
          "path": ["haproxy", "config"]
        }
      }
    },
    {
      "name": "HAProxy List Configs",
      "request": {
        "method": "GET",
        "header": [
          { "key": "X-API-Key", "value": "{{API_KEY}}", "disabled": true }
        ],
        "url": {
          "raw": "http://{{API_HOST}}:{{API_PORT}}/haproxy/configs",
          "protocol": "http",
          "host": ["{{API_HOST}}"],
          "port": "{{API_PORT}}",
          "path": ["haproxy", "configs"]
        }
      }
    },
    {
      "name": "HAProxy Reload",
      "request": {
        "method": "POST",
        "header": [
          { "key": "X-API-Key", "value": "{{API_KEY}}", "disabled": true }
        ],
        "url": {
          "raw": "http://{{API_HOST}}:{{API_PORT}}/haproxy/reload",
          "protocol": "http",
          "host": ["{{API_HOST}}"],
          "port": "{{API_PORT}}",
          "path": ["haproxy", "reload"]
        }
      }
    },
    {
      "name": "MySQL Deploy",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "X-API-Key", "value": "{{API_KEY}}", "disabled": true }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"root_password\": \"{{ROOT_PASSWORD}}\",\n  \"cluster_admin_username\": \"{{CLUSTER_ADMIN_USERNAME}}\",\n  \"cluster_admin_password\": \"{{CLUSTER_ADMIN_PASSWORD}}\",\n  \"cluster_name\": \"{{CLUSTER_NAME}}\",\n  \"primary_ip\": \"{{PRIMARY_IP}}\",\n  \"secondary_ips\": [\"{{SECONDARY_IP}}\"],\n  \"assume_prepared\": false,\n  \"bootstrap_router\": true,\n  \"ssh_user\": \"root\",\n  \"ssh_password\": \"{{SSH_PASSWORD}}\",\n  \"ssh_port\": 22,\n  \"mysql_port\": 3306,\n  \"step_timeout_seconds\": 900\n}"
        },
        "url": {
          "raw": "http://{{API_HOST}}:{{API_PORT}}/cluster/mysql/deploy",
          "protocol": "http",
          "host": ["{{API_HOST}}"],
          "port": "{{API_PORT}}",
          "path": ["cluster", "mysql", "deploy"]
        }
      }
    },
    {
      "name": "MySQL List Jobs",
      "request": {
        "method": "GET",
        "header": [
          { "key": "X-API-Key", "value": "{{API_KEY}}", "disabled": true }
        ],
        "url": {
          "raw": "http://{{API_HOST}}:{{API_PORT}}/cluster/mysql/jobs?limit=20",
          "protocol": "http",
          "host": ["{{API_HOST}}"],
          "port": "{{API_PORT}}",
          "path": ["cluster", "mysql", "jobs"],
          "query": [
            { "key": "limit", "value": "20" }
          ]
        }
      }
    },
    {
      "name": "MySQL Get Job",
      "request": {
        "method": "GET",
        "header": [
          { "key": "X-API-Key", "value": "{{API_KEY}}", "disabled": true }
        ],
        "url": {
          "raw": "http://{{API_HOST}}:{{API_PORT}}/cluster/mysql/jobs/{{JOB_ID}}",
          "protocol": "http",
          "host": ["{{API_HOST}}"],
          "port": "{{API_PORT}}",
          "path": ["cluster", "mysql", "jobs", "{{JOB_ID}}"]
        }
      }
    },
    {
      "name": "MySQL Resume Job",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "X-API-Key", "value": "{{API_KEY}}", "disabled": true }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"root_password\": \"{{ROOT_PASSWORD}}\",\n  \"cluster_admin_password\": \"{{CLUSTER_ADMIN_PASSWORD}}\",\n  \"ssh_password\": \"{{SSH_PASSWORD}}\"\n}"
        },
        "url": {
          "raw": "http://{{API_HOST}}:{{API_PORT}}/cluster/mysql/jobs/{{JOB_ID}}/resume",
          "protocol": "http",
          "host": ["{{API_HOST}}"],
          "port": "{{API_PORT}}",
          "path": ["cluster", "mysql", "jobs", "{{JOB_ID}}", "resume"]
        }
      }
    },
    {
      "name": "MySQL Rollback Job",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "X-API-Key", "value": "{{API_KEY}}", "disabled": true }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"root_password\": \"{{ROOT_PASSWORD}}\",\n  \"cluster_admin_password\": \"{{CLUSTER_ADMIN_PASSWORD}}\",\n  \"ssh_password\": \"{{SSH_PASSWORD}}\"\n}"
        },
        "url": {
          "raw": "http://{{API_HOST}}:{{API_PORT}}/cluster/mysql/jobs/{{JOB_ID}}/rollback",
          "protocol": "http",
          "host": ["{{API_HOST}}"],
          "port": "{{API_PORT}}",
          "path": ["cluster", "mysql", "jobs", "{{JOB_ID}}", "rollback"]
        }
      }
    }
  ]
}
