{
  "info": {
    "_postman_id": "0f487bb5-3f07-49a9-9b29-e468f795d8d5",
    "name": "Erawan Cluster API (Go)",
    "description": "Postman collection for HAProxy, MySQL cluster, and PostgreSQL cluster endpoints. PostgreSQL Patroni/etcd deployment supports either single-node primary-only mode or primary-plus-standby mode.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "API_HOST", "value": "127.0.0.1" },
    { "key": "API_PORT", "value": "8080" },
    { "key": "API_KEY", "value": "" },
    { "key": "JOB_ID", "value": "" },
    { "key": "ROOT_PASSWORD", "value": "RootPass#2026" },
    { "key": "CLUSTER_ADMIN_USERNAME", "value": "clusteradmin" },
    { "key": "CLUSTER_ADMIN_PASSWORD", "value": "ClusterAdmin#2026" },
    { "key": "SSH_PASSWORD", "value": "password" },
    { "key": "PRIMARY_IP", "value": "192.168.122.154" },
    { "key": "SECONDARY_IP", "value": "192.168.122.111" },
    { "key": "CLUSTER_NAME", "value": "prodCluster" },
    { "key": "NEW_USER", "value": "appuser" },
    { "key": "NEW_USER_PASSWORD", "value": "AppUser#2026" },
    { "key": "NEW_USER_SSL_REQUIRED", "value": "true" },
    { "key": "NEW_DB", "value": "appdb" },
    { "key": "PGSQL_PRIMARY_IP", "value": "10.0.0.1" },
    { "key": "PGSQL_STANDBY_IP_1", "value": "10.0.0.2" },
    { "key": "PGSQL_STANDBY_IP_2", "value": "10.0.0.3" },
    { "key": "POSTGRES_PASSWORD", "value": "postgrespassword" },
    { "key": "REPLICATOR_PASSWORD", "value": "replicatorpassword" },
    { "key": "PATRONI_ADMIN_PASSWORD", "value": "adminpassword" }
  ],
  "item": [
    {
      "name": "Health & Docs",
      "item": [
        {
          "name": "Health",
          "request": {
            "method": "GET",
            "header": [
              { "key": "X-API-Key", "value": "{{API_KEY}}", "disabled": true }
            ],
            "url": {
              "raw": "http://{{API_HOST}}:{{API_PORT}}/health",
              "protocol": "http",
              "host": ["{{API_HOST}}"],
              "port": "{{API_PORT}}",
              "path": ["health"]
            }
          }
        },
        {
          "name": "Docs",
          "request": {
            "method": "GET",
            "header": [
              { "key": "X-API-Key", "value": "{{API_KEY}}", "disabled": true }
            ],
            "url": {
              "raw": "http://{{API_HOST}}:{{API_PORT}}/docs",
              "protocol": "http",
              "host": ["{{API_HOST}}"],
              "port": "{{API_PORT}}",
              "path": ["docs"]
            }
          }
        }
      ]
    },
    {
      "name": "HAProxy",
      "item": [
        {
          "name": "Create Config",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-API-Key", "value": "{{API_KEY}}", "disabled": true }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"port\": 25010,\n  \"node_ips\": [\"10.10.107.182\", \"10.10.107.183\"],\n  \"db_port\": 6446\n}"
            },
            "url": {
              "raw": "http://{{API_HOST}}:{{API_PORT}}/haproxy/config",
              "protocol": "http",
              "host": ["{{API_HOST}}"],
              "port": "{{API_PORT}}",
              "path": ["haproxy", "config"]
            }
          }
        },
        {
          "name": "Delete Config",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-API-Key", "value": "{{API_KEY}}", "disabled": true }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"port\": 25010\n}"
            },
            "url": {
              "raw": "http://{{API_HOST}}:{{API_PORT}}/haproxy/config",
              "protocol": "http",
              "host": ["{{API_HOST}}"],
              "port": "{{API_PORT}}",
              "path": ["haproxy", "config"]
            }
          }
        },
        {
          "name": "List Configs",
          "request": {
            "method": "GET",
            "header": [
              { "key": "X-API-Key", "value": "{{API_KEY}}", "disabled": true }
            ],
            "url": {
              "raw": "http://{{API_HOST}}:{{API_PORT}}/haproxy/configs",
              "protocol": "http",
              "host": ["{{API_HOST}}"],
              "port": "{{API_PORT}}",
              "path": ["haproxy", "configs"]
            }
          }
        },
        {
          "name": "Reload",
          "request": {
            "method": "POST",
            "header": [
              { "key": "X-API-Key", "value": "{{API_KEY}}", "disabled": true }
            ],
            "url": {
              "raw": "http://{{API_HOST}}:{{API_PORT}}/haproxy/reload",
              "protocol": "http",
              "host": ["{{API_HOST}}"],
              "port": "{{API_PORT}}",
              "path": ["haproxy", "reload"]
            }
          }
        }
      ]
    },
    {
      "name": "Cluster - MySQL",
      "item": [
        {
          "name": "Deploy",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-API-Key", "value": "{{API_KEY}}", "disabled": true }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"root_password\": \"{{ROOT_PASSWORD}}\",\n  \"cluster_admin_username\": \"{{CLUSTER_ADMIN_USERNAME}}\",\n  \"cluster_admin_password\": \"{{CLUSTER_ADMIN_PASSWORD}}\",\n  \"cluster_name\": \"{{CLUSTER_NAME}}\",\n  \"primary_ip\": \"{{PRIMARY_IP}}\",\n  \"secondary_ips\": [\"{{SECONDARY_IP}}\"],\n  \"new_user\": \"{{NEW_USER}}\",\n  \"new_user_password\": \"{{NEW_USER_PASSWORD}}\",\n  \"new_user_ssl_required\": {{NEW_USER_SSL_REQUIRED}},\n  \"new_db\": \"{{NEW_DB}}\",\n  \"assume_prepared\": false,\n  \"bootstrap_router\": true,\n  \"ssh_user\": \"root\",\n  \"ssh_password\": \"{{SSH_PASSWORD}}\",\n  \"ssh_port\": 22,\n  \"mysql_port\": 3306,\n  \"step_timeout_seconds\": 900\n}"
            },
            "url": {
              "raw": "http://{{API_HOST}}:{{API_PORT}}/cluster/mysql/deploy",
              "protocol": "http",
              "host": ["{{API_HOST}}"],
              "port": "{{API_PORT}}",
              "path": ["cluster", "mysql", "deploy"]
            }
          }
        },
        {
          "name": "List Jobs",
          "request": {
            "method": "GET",
            "header": [
              { "key": "X-API-Key", "value": "{{API_KEY}}", "disabled": true }
            ],
            "url": {
              "raw": "http://{{API_HOST}}:{{API_PORT}}/cluster/mysql/jobs?limit=20",
              "protocol": "http",
              "host": ["{{API_HOST}}"],
              "port": "{{API_PORT}}",
              "path": ["cluster", "mysql", "jobs"],
              "query": [
                { "key": "limit", "value": "20" }
              ]
            }
          }
        },
        {
          "name": "Get Job",
          "request": {
            "method": "GET",
            "header": [
              { "key": "X-API-Key", "value": "{{API_KEY}}", "disabled": true }
            ],
            "url": {
              "raw": "http://{{API_HOST}}:{{API_PORT}}/cluster/mysql/jobs/{{JOB_ID}}",
              "protocol": "http",
              "host": ["{{API_HOST}}"],
              "port": "{{API_PORT}}",
              "path": ["cluster", "mysql", "jobs", "{{JOB_ID}}"]
            }
          }
        },
        {
          "name": "Resume Job",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-API-Key", "value": "{{API_KEY}}", "disabled": true }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"root_password\": \"{{ROOT_PASSWORD}}\",\n  \"cluster_admin_password\": \"{{CLUSTER_ADMIN_PASSWORD}}\",\n  \"ssh_password\": \"{{SSH_PASSWORD}}\",\n  \"new_user_password\": \"{{NEW_USER_PASSWORD}}\"\n}"
            },
            "url": {
              "raw": "http://{{API_HOST}}:{{API_PORT}}/cluster/mysql/jobs/{{JOB_ID}}/resume",
              "protocol": "http",
              "host": ["{{API_HOST}}"],
              "port": "{{API_PORT}}",
              "path": ["cluster", "mysql", "jobs", "{{JOB_ID}}", "resume"]
            }
          }
        },
        {
          "name": "Rollback Job",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-API-Key", "value": "{{API_KEY}}", "disabled": true }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"root_password\": \"{{ROOT_PASSWORD}}\",\n  \"cluster_admin_password\": \"{{CLUSTER_ADMIN_PASSWORD}}\",\n  \"ssh_password\": \"{{SSH_PASSWORD}}\"\n}"
            },
            "url": {
              "raw": "http://{{API_HOST}}:{{API_PORT}}/cluster/mysql/jobs/{{JOB_ID}}/rollback",
              "protocol": "http",
              "host": ["{{API_HOST}}"],
              "port": "{{API_PORT}}",
              "path": ["cluster", "mysql", "jobs", "{{JOB_ID}}", "rollback"]
            }
          }
        }
      ]
    },
    {
      "name": "Cluster - PostgreSQL",
      "description": "PostgreSQL supports either a single primary node or a primary with one or more standby nodes.",
      "item": [
        {
          "name": "Deploy",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-API-Key", "value": "{{API_KEY}}", "disabled": true }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"cluster_name\": \"{{CLUSTER_NAME}}\",\n  \"primary_ip\": \"{{PGSQL_PRIMARY_IP}}\",\n  \"standby_ips\": [],\n  \"postgres_password\": \"{{POSTGRES_PASSWORD}}\",\n  \"replicator_password\": \"{{REPLICATOR_PASSWORD}}\",\n  \"admin_password\": \"{{PATRONI_ADMIN_PASSWORD}}\",\n  \"new_user\": \"{{NEW_USER}}\",\n  \"new_user_password\": \"{{NEW_USER_PASSWORD}}\",\n  \"new_db\": \"{{NEW_DB}}\",\n  \"ssh_user\": \"root\",\n  \"ssh_password\": \"{{SSH_PASSWORD}}\",\n  \"ssh_port\": 22,\n  \"postgres_port\": 5432,\n  \"step_timeout_seconds\": 900\n}"
            },
            "description": "Use `standby_ips: []` for primary-only mode, or provide one or more standby IPs for HA mode.",
            "url": {
              "raw": "http://{{API_HOST}}:{{API_PORT}}/cluster/pgsql/deploy",
              "protocol": "http",
              "host": ["{{API_HOST}}"],
              "port": "{{API_PORT}}",
              "path": ["cluster", "pgsql", "deploy"]
            }
          }
        },
        {
          "name": "List Jobs",
          "request": {
            "method": "GET",
            "header": [
              { "key": "X-API-Key", "value": "{{API_KEY}}", "disabled": true }
            ],
            "url": {
              "raw": "http://{{API_HOST}}:{{API_PORT}}/cluster/pgsql/jobs?limit=20",
              "protocol": "http",
              "host": ["{{API_HOST}}"],
              "port": "{{API_PORT}}",
              "path": ["cluster", "pgsql", "jobs"],
              "query": [
                { "key": "limit", "value": "20" }
              ]
            }
          }
        },
        {
          "name": "Get Job",
          "request": {
            "method": "GET",
            "header": [
              { "key": "X-API-Key", "value": "{{API_KEY}}", "disabled": true }
            ],
            "url": {
              "raw": "http://{{API_HOST}}:{{API_PORT}}/cluster/pgsql/jobs/{{JOB_ID}}",
              "protocol": "http",
              "host": ["{{API_HOST}}"],
              "port": "{{API_PORT}}",
              "path": ["cluster", "pgsql", "jobs", "{{JOB_ID}}"]
            }
          }
        },
        {
          "name": "Resume Job",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-API-Key", "value": "{{API_KEY}}", "disabled": true }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"postgres_password\": \"{{POSTGRES_PASSWORD}}\",\n  \"replicator_password\": \"{{REPLICATOR_PASSWORD}}\",\n  \"admin_password\": \"{{PATRONI_ADMIN_PASSWORD}}\",\n  \"ssh_password\": \"{{SSH_PASSWORD}}\",\n  \"new_user_password\": \"{{NEW_USER_PASSWORD}}\"\n}"
            },
            "url": {
              "raw": "http://{{API_HOST}}:{{API_PORT}}/cluster/pgsql/jobs/{{JOB_ID}}/resume",
              "protocol": "http",
              "host": ["{{API_HOST}}"],
              "port": "{{API_PORT}}",
              "path": ["cluster", "pgsql", "jobs", "{{JOB_ID}}", "resume"]
            }
          }
        }
      ]
    }
  ]
}
