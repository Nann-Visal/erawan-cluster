{
  "info": {
    "name": "Erawan Cluster API (Go)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Go API collection for HAProxy and MySQL cluster automation"
  },
  "variable": [
    { "key": "API_HOST", "value": "http://127.0.0.1" },
    { "key": "API_PORT", "value": "8080" },
    { "key": "API_KEY", "value": "" },
    { "key": "JOB_ID", "value": "" }
  ],
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "header": [
          { "key": "X-API-Key", "value": "{{API_KEY}}", "disabled": true }
        ],
        "url": "{{API_HOST}}:{{API_PORT}}/health"
      }
    },
    {
      "name": "Docs",
      "request": {
        "method": "GET",
        "header": [
          { "key": "X-API-Key", "value": "{{API_KEY}}", "disabled": true }
        ],
        "url": "{{API_HOST}}:{{API_PORT}}/docs"
      }
    },
    {
      "name": "HAProxy Create Config",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "X-API-Key", "value": "{{API_KEY}}", "disabled": true }
        ],
        "url": "{{API_HOST}}:{{API_PORT}}/haproxy/config",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"port\": 25010,\n  \"node_ips\": [\"10.10.107.182\", \"10.10.107.183\"],\n  \"db_port\": 6446\n}"
        }
      }
    },
    {
      "name": "HAProxy Delete Config",
      "request": {
        "method": "DELETE",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "X-API-Key", "value": "{{API_KEY}}", "disabled": true }
        ],
        "url": "{{API_HOST}}:{{API_PORT}}/haproxy/config",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"port\": 25010\n}"
        }
      }
    },
    {
      "name": "HAProxy List Configs",
      "request": {
        "method": "GET",
        "header": [
          { "key": "X-API-Key", "value": "{{API_KEY}}", "disabled": true }
        ],
        "url": "{{API_HOST}}:{{API_PORT}}/haproxy/configs"
      }
    },
    {
      "name": "HAProxy Reload",
      "request": {
        "method": "POST",
        "header": [
          { "key": "X-API-Key", "value": "{{API_KEY}}", "disabled": true }
        ],
        "url": "{{API_HOST}}:{{API_PORT}}/haproxy/reload"
      }
    },
    {
      "name": "MySQL Deploy",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "X-API-Key", "value": "{{API_KEY}}", "disabled": true }
        ],
        "url": "{{API_HOST}}:{{API_PORT}}/cluster/mysql/deploy",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"root_password\": \"RootPass#2026\",\n  \"cluster_admin_username\": \"clusteradmin\",\n  \"cluster_admin_password\": \"ClusterAdmin#2026\",\n  \"cluster_name\": \"sambar6Cluster\",\n  \"primary_ip\": \"192.168.122.154\",\n  \"secondary_ips\": [\"192.168.122.111\"],\n  \"assume_prepared\": false,\n  \"bootstrap_router\": true,\n  \"ssh_user\": \"root\",\n  \"ssh_password\": \"password\",\n  \"ssh_port\": 22,\n  \"mysql_port\": 3306,\n  \"router_base_port\": 6446,\n  \"step_timeout_seconds\": 900\n}"
        }
      }
    },
    {
      "name": "MySQL List Jobs",
      "request": {
        "method": "GET",
        "header": [
          { "key": "X-API-Key", "value": "{{API_KEY}}", "disabled": true }
        ],
        "url": "{{API_HOST}}:{{API_PORT}}/cluster/mysql/jobs?limit=20"
      }
    },
    {
      "name": "MySQL Get Job",
      "request": {
        "method": "GET",
        "header": [
          { "key": "X-API-Key", "value": "{{API_KEY}}", "disabled": true }
        ],
        "url": "{{API_HOST}}:{{API_PORT}}/cluster/mysql/jobs/{{JOB_ID}}"
      }
    },
    {
      "name": "MySQL Resume Job",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "X-API-Key", "value": "{{API_KEY}}", "disabled": true }
        ],
        "url": "{{API_HOST}}:{{API_PORT}}/cluster/mysql/jobs/{{JOB_ID}}/resume",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"cluster_admin_password\": \"ClusterAdmin#2026\",\n  \"ssh_password\": \"password\"\n}"
        }
      }
    },
    {
      "name": "MySQL Rollback Job",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "X-API-Key", "value": "{{API_KEY}}", "disabled": true }
        ],
        "url": "{{API_HOST}}:{{API_PORT}}/cluster/mysql/jobs/{{JOB_ID}}/rollback",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"cluster_admin_password\": \"ClusterAdmin#2026\",\n  \"ssh_password\": \"password\"\n}"
        }
      }
    }
  ]
}
